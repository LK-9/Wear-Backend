Replace the main product section with:

```html
@extends('layouts.app') @section('content')
<div class="container">
    <div class="product-detail">
        <div class="product-gallery">
            @if($product->primaryImage)
            <img
                src="{{ $product->primaryImage->image_url }}"
                alt="{{ $product->primaryImage->alt_text ?? $product->name }}"
                class="main-product-image"
            />
            @else
            <img
                src="/images/placeholder-product.jpg"
                alt="{{ $product->name }}"
                class="main-product-image"
            />
            @endif @if($product->images->count() > 1)
            <div class="product-thumbnails">
                @foreach($product->images as $image)
                <img
                    src="{{ $image->image_url }}"
                    alt="{{ $image->alt_text ?? $product->name }}"
                    class="thumbnail {{ $image->is_primary ? 'active' : '' }}"
                />
                @endforeach
            </div>
            @endif
        </div>

        <div class="product-info">
            <h1 class="product-title">{{ $product->name }}</h1>

            <div class="product-meta">
                <span class="product-category">
                    Category:
                    <a
                        href="{{ route('shop', ['category' => $product->category->id]) }}"
                        >{{ $product->category->name }}</a
                    >
                </span>

                <div class="product-rating">
                    @for($i = 1; $i <= 5; $i++)
                    <span
                        class="star {{ $i <= $product->average_rating ? 'filled' : '' }}"
                        >★</span
                    >
                    @endfor
                    <span class="rating-count"
                        >({{ $product->review_count }} reviews)</span
                    >
                </div>

                <div class="stock-status">
                    @if($product->stock > 10)
                    <span class="in-stock"
                        >✓ In Stock ({{ $product->stock }} available)</span
                    >
                    @elseif($product->stock > 0)
                    <span class="low-stock"
                        >⚠ Only {{ $product->stock }} left in stock</span
                    >
                    @else
                    <span class="out-of-stock">✗ Out of Stock</span>
                    @endif
                </div>
            </div>

            <div class="product-price">
                <span class="price"
                    >${{ number_format($product->price, 2) }}</span
                >
            </div>

            <div class="product-description">
                <h3>Description</h3>
                <p>{{ $product->description }}</p>
            </div>

            @if($product->stock > 0)
            <div class="add-to-cart-section">
                <form
                    action="{{ route('cart.add') }}"
                    method="POST"
                    class="add-to-cart-form"
                >
                    @csrf
                    <input
                        type="hidden"
                        name="product_id"
                        value="{{ $product->id }}"
                    />

                    <div class="quantity-selector">
                        <label for="quantity">Quantity:</label>
                        <input
                            type="number"
                            id="quantity"
                            name="quantity"
                            value="1"
                            min="1"
                            max="{{ min($product->stock, 99) }}"
                            class="quantity-input"
                        />
                    </div>

                    <button type="submit" class="add-to-cart-btn">
                        Add to Cart - ${{ number_format($product->price, 2) }}
                    </button>
                </form>
            </div>
            @else
            <div class="out-of-stock-notice">
                <p>
                    This product is currently out of stock. Please check back
                    later.
                </p>
                <button
                    class="notify-btn"
                    onclick="alert('Notification feature coming soon!')"
                >
                    Notify When Available
                </button>
            </div>
            @endif

            <div class="product-actions">
                @auth @php $isInWishlist =
                auth()->user()->wishlist()->where('product_id',
                $product->id)->exists(); @endphp
                <form
                    action="{{ $isInWishlist ? route('wishlist.remove', $product) : route('wishlist.add', $product) }}"
                    method="POST"
                    class="wishlist-form"
                >
                    @csrf @if($isInWishlist) @method('DELETE')
                    <button type="submit" class="wishlist-btn in-wishlist">
                        ♥ Remove from Wishlist
                    </button>
                    @else
                    <button type="submit" class="wishlist-btn">
                        ♡ Add to Wishlist
                    </button>
                    @endif
                </form>
                @else
                <a href="{{ route('login') }}" class="wishlist-btn"
                    >♡ Add to Wishlist (Login Required)</a
                >
                @endauth

                <button
                    class="share-btn"
                    onclick="navigator.share({title: '{{ $product->name }}', url: window.location.href})"
                >
                    📤 Share Product
                </button>
            </div>
        </div>
    </div>

    <!-- Related Products -->
    @if($relatedProducts->count() > 0)
    <div class="related-products">
        <h2>Related Products</h2>
        <div class="related-grid">
            @foreach($relatedProducts as $relatedProduct)
            <div class="related-card">
                <div class="related-image">
                    @if($relatedProduct->primaryImage)
                    <img
                        src="{{ $relatedProduct->primaryImage->image_url }}"
                        alt="{{ $relatedProduct->primaryImage->alt_text ?? $relatedProduct->name }}"
                    />
                    @else
                    <img
                        src="/images/placeholder-product.jpg"
                        alt="{{ $relatedProduct->name }}"
                    />
                    @endif
                </div>
                <div class="related-info">
                    <h4>
                        <a
                            href="{{ route('shop-details', $relatedProduct->slug) }}"
                            >{{ $relatedProduct->name }}</a
                        >
                    </h4>
                    <p class="related-price">
                        ${{ number_format($relatedProduct->price, 2) }}
                    </p>
                </div>
            </div>
            @endforeach
        </div>
    </div>
    @endif

    <!-- Product Reviews -->
    @if($product->reviews->count() > 0)
    <div class="product-reviews">
        <h2>Customer Reviews</h2>
        <div class="reviews-list">
            @foreach($product->reviews as $review)
            <div class="review-item">
                <div class="review-header">
                    <div class="review-rating">
                        @for($i = 1; $i <= 5; $i++)
                        <span
                            class="star {{ $i <= $review->rating ? 'filled' : '' }}"
                            >★</span
                        >
                        @endfor
                    </div>
                    <div class="review-meta">
                        <span class="review-author"
                            >{{ $review->user->name }}</span
                        >
                        <span class="review-date"
                            >{{ $review->created_at->format('M j, Y') }}</span
                        >
                        @if($review->is_verified_purchase)
                        <span class="verified-badge">✓ Verified Purchase</span>
                        @endif
                    </div>
                </div>
                <div class="review-content">
                    <p>{{ $review->comment }}</p>
                </div>
            </div>
            @endforeach
        </div>
    </div>
    @endif
</div>
@endsection
```

